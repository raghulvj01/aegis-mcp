# MCP service configuration
MCP_SERVICE_NAME=aegis
MCP_ENV=dev

# Policy file paths
MCP_ROLES_FILE=policies/roles.yaml
MCP_SCOPES_FILE=policies/scope_rules.yaml

# OIDC / JWT validation (optional — leave unset to skip issuer/audience checks)
# OIDC_ISSUER=https://idp.example.com
# OIDC_AUDIENCE=aegis-api

# Telegram MCP bridge (optional)
# TELEGRAM_BOT_TOKEN=123456:your-bot-token
# MCP_SERVER_URL=http://127.0.0.1:8000/mcp
# MCP_HEALTH_URL=http://127.0.0.1:8000/health
# MCP_TOOL_TOKEN=optional-jwt-for-tool-token-arg
# MCP_HTTP_AUTH_BEARER=optional-http-bearer-token
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# Mistral AI (optional, required only for /ask command)
# MISTRAL_API_KEY=your-mistral-api-key
# MISTRAL_MODEL=mistral-small-latest
# MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
